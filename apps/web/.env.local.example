NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Amazon Associates affiliate tag ──────────────────────────────────────────
# Sign up: https://affiliate-program.amazon.com/
# After approval, find your tag in: Associates Central → Account → Manage Your Tracking IDs
# Format: yourname-20  (the "-20" suffix is standard for US Associates)
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=

# ── Google AdSense ─────────────────────────────────────────────────────────────
# Sign up: https://adsense.google.com/
# Publisher ID: AdSense dashboard → Account → Account information → Publisher ID
# Format: pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=

# Ad unit slot IDs — create these in AdSense: Ads → By ad unit → Display ad
# Copy the numeric slot ID (e.g. 1234567890) from the generated code snippet
#
# Slot shown between listing cards on search/category pages
NEXT_PUBLIC_ADSENSE_SLOT_LISTINGS=
#
# Slot shown on the estate sales browse page (top banner)
NEXT_PUBLIC_ADSENSE_SLOT_ESTATE=
#
# Slot shown on individual listing detail pages (below AI tools)
NEXT_PUBLIC_ADSENSE_SLOT_LISTING_DETAIL=

# ── Google Analytics 4 ─────────────────────────────────────────────────────────
# Format: G-XXXXXXXXXX  (find in GA4 > Admin > Data Streams > your stream > Measurement ID)
NEXT_PUBLIC_GA4_ID=

# GA4 Measurement Protocol — server-side tracking for affiliate click-outs
# GA4 > Admin > Data Streams > your stream > Measurement Protocol API secrets
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for: Claude Vision lens, AI price checker, valuation endpoint
# Get key: https://console.anthropic.com/ → API Keys → Create Key
ANTHROPIC_API_KEY=
