# ============================================================
# Estate Scout - Environment Variables
# Copy this to .env and fill in values
# Keys marked (optional) let the app run without them
# ============================================================

# --- Database ---
POSTGRES_USER=estate_scout
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=estate_scout
DATABASE_URL=postgresql+asyncpg://estate_scout:changeme_in_production@localhost:5432/estate_scout

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI Services (optional) ---
# Without these, valuation returns comparable sales with a template response (no LLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Authentication ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-real-secret-here-64-chars-minimum

# --- Scraping ---
# (optional) Comma-separated proxy URLs: http://user:pass@host:port
PROXY_URLS=

# --- Frontend API URL ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# For physical device testing, use your LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# --- Payments (optional, for Pro tier Stripe checkout) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...        # Create in Stripe Dashboard → Products → Pro Plan
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URL used for Stripe redirect URLs (success/cancel) — set to your production domain
WEB_URL=http://localhost:3000

# --- Admin endpoints (optional) ---
# Set this to enable /api/v1/admin/* endpoints (stats, trigger scrape, etc.)
# Pass as X-Admin-Key header. Leave blank to disable admin routes entirely.
ADMIN_SECRET_KEY=

# --- Email (optional, for search alerts) ---
SENDGRID_API_KEY=
FROM_EMAIL=noreply@estatescout.app

# --- Ads (optional, populate when ready to monetize) ---
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=
